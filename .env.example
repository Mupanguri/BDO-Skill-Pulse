# Environment Variables Configuration
# Copy this file to .env and fill in your values

# For production, set the API base URL
# Leave empty for same-domain deployment (development or Vercel with serverless API)
VITE_API_URL=

# Database (for backend)
DATABASE_URL=postgresql://postgres:your_password@your_host:5432/bdo_quiz_system

# JWT Secrets (generate secure random strings for production)
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# Server
PORT=3001
NODE_ENV=production
